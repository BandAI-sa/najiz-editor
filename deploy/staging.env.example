APP_ENV=staging
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENCRYPTION_KEY=replace-with-a-long-random-value

LLM_PROVIDER=openai
LLM_ENABLE=false
OPENAI_API_KEY=

# Keep false anywhere the admin dashboard must retain history across restarts.
USE_MEMORY_STORE=false
MONGODB_URI=mongodb://host.docker.internal:27017
MONGODB_DATABASE=najiz_legal_agent_staging

COMPOSE_PROJECT_NAME=najiz-pr-staging
BACKEND_PORT=18000
FRONTEND_PORT=13000
CORS_ORIGINS=http://YOUR_VPS_IP:13000
APP_ALLOWED_HOSTS=YOUR_VPS_IP,localhost,127.0.0.1,backend
