LLM_PROVIDER=openai
LLM_ENABLE=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_CLASSIFIER_MODEL=
OPENAI_INTERVIEWER_MODEL=
OPENAI_DRAFTER_MODEL=
OPENAI_REVIEWER_MODEL=
OPENAI_GUARD_MODEL=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CLASSIFIER_MODEL=
GEMINI_INTERVIEWER_MODEL=
GEMINI_DRAFTER_MODEL=
GEMINI_REVIEWER_MODEL=
GEMINI_GUARD_MODEL=

CLASSIFY_TEMPERATURE=0.2
INTERVIEW_TEMPERATURE=0.3
DRAFT_TEMPERATURE=0.4
REVIEW_TEMPERATURE=0.2

CLASSIFY_MAX_TOKENS=800
INTERVIEW_MAX_TOKENS=400
DRAFT_MAX_TOKENS=3000
REVIEW_MAX_TOKENS=2000

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=najiz_legal_agent
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_AUTH_SOURCE=
USE_MEMORY_STORE=false
ALLOW_VOLATILE_MEMORY_STORE=false
# Keep false for staging/production unless Mongo is intentionally on the same host as the app process.
ALLOW_LOCALHOST_MONGODB_IN_PROTECTED_ENV=false
ALLOW_UNAUTHENTICATED_MONGODB_IN_PROTECTED_ENV=false

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_ALLOWED_HOSTS=localhost,127.0.0.1,backend
APP_ENCRYPTION_KEY=

# Informational only today; records stay in storage until manual deletion from Admin Dashboard.
SESSION_EXPIRY_HOURS=24
# Warn when a session gets long; this does not delete data.
SESSION_TURN_LIMIT=30
# Reserved for future draft-history limits; not enforced automatically in the current app.
PETITION_VERSION_LIMIT=10
# Trigger a high-value dispute warning for manual review.
DISPUTE_VALUE_THRESHOLD=100000
